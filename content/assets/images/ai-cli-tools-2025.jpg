<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">  <!-- Background with gradient -->  <defs>    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">      <stop offset="0%" style="stop-color:#1a1d23;stop-opacity:1" />      <stop offset="100%" style="stop-color:#2d3748;stop-opacity:1" />    </linearGradient>  </defs>    <rect width="1200" height="630" fill="url(#grad1)"/>    <!-- Grid pattern overlay -->  <defs>    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#4a5568" stroke-width="0.5" opacity="0.3"/>    </pattern>  </defs>  <rect width="1200" height="630" fill="url(#grid)"/>    <!-- Terminal window -->  <rect x="100" y="120" width="1000" height="430" rx="10" fill="#0d1117" stroke="#30363d" stroke-width="2"/>    <!-- Terminal header -->  <rect x="100" y="120" width="1000" height="40" rx="10" fill="#161b22"/>  <circle cx="125" cy="140" r="6" fill="#ff5f56"/>  <circle cx="145" cy="140" r="6" fill="#ffbd2e"/>  <circle cx="165" cy="140" r="6" fill="#27c93f"/>    <!-- Terminal content -->  <text x="130" y="210" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#58a6ff">    $ gh copilot suggest  </text>    <text x="130" y="255" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#7ee787">    $ sgpt "explain this code"  </text>    <text x="130" y="300" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#ffa657">    $ warp-ai  </text>    <text x="130" y="345" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#f778ba">    $ aider --model gpt-4  </text>    <text x="130" y="390" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#79c0ff">    $ k8sgpt analyze  </text>    <text x="130" y="435" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#d2a8ff">    $ mods "summarize logs"  </text>    <text x="130" y="480" font-family="'Monaco', 'Courier New', monospace" font-size="22" fill="#ff9e64">    $ claude "debug issue"  </text>    <text x="130" y="520" font-family="'Monaco', 'Courier New', monospace" font-size="20" fill="#8b949e">    ▊  </text></svg>